# /etc/logrotate.d/clash-host-agent
#
# Log rotation for PolyClaw host-agent audit and application logs.
# Installed by: crates/host-agent/install.sh (install_logrotate())
#
# Rotation policy:
#   - Daily rotation or when size exceeds 100 MiB (whichever comes first).
#   - Retain 14 compressed archives per log file.
#   - copytruncate is NOT used; instead a postrotate SIGHUP (or systemctl
#     reload) tells the daemon to reopen its log file descriptor.

/var/log/clash/audit.jsonl
/var/log/clash/host-agent.log
/var/log/clash/zfs-destroy-wrapper.log
{
    # Rotate at least daily; also rotate early if file exceeds 100 MiB.
    # maxsize triggers mid-cycle rotation without replacing the daily schedule.
    daily
    maxsize 100M
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    dateext
    dateformat -%Y%m%d
    # Note: 'clash-agent' user is created by install.sh (useradd).
    # logrotate --debug will report "unknown user" on systems where the
    # service account has not yet been created — this is expected.
    create 640 clash-agent clash-agent

    postrotate
        # Try systemctl reload first (preferred when systemd is available).
        # Fall back to SIGHUP directly if systemctl is not found or fails.
        if command -v systemctl >/dev/null 2>&1; then
            systemctl reload clash-host-agent 2>/dev/null || \
            systemctl kill --kill-who=main --signal=HUP clash-host-agent 2>/dev/null || \
            true
        else
            # SysV / standalone: send SIGHUP to the main PID
            pid_file=/var/run/clash-host-agent.pid
            if [ -f "$pid_file" ]; then
                pid=$(cat "$pid_file")
                if kill -0 "$pid" 2>/dev/null; then
                    kill -HUP "$pid"
                fi
            fi
        fi
    endscript
}
