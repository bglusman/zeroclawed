# /etc/sudoers.d/clash-agent
#
# PolyClaw host-agent sudoers fragment — WRAPPER-ONLY policy
#
# IMPORTANT: This file restricts clash-agent to the three wrapper scripts
# only.  Do NOT grant broad /sbin/zfs, /usr/sbin/pct, or /usr/bin/git access;
# those broad entries are the anti-pattern this file replaces.
#
# Variables to substitute before deploying (or let install.sh fill them in):
#   {{CLASH_AGENT_USER}}  — system account running host-agent (e.g. clash-agent)
#
# Generated by: crates/host-agent/install.sh (install_sudoers())
# Template:     crates/host-agent/wrappers/sudoers-clash-agent.template
#
# After editing, always validate with:
#   visudo -cf /etc/sudoers.d/clash-agent
#

# ------ pct-create wrapper -------------------------------------------------
# Allows clash-agent to create new LXC containers through the validated
# pct-create-wrapper only.  pct start/stop/status are handled separately
# or via the adapter's direct sudo entries below.
{{CLASH_AGENT_USER}} ALL=(root) NOPASSWD: /usr/local/sbin/pct-create-wrapper

# ------ zfs-destroy wrapper ------------------------------------------------
# Only active when wrappers.zfs_destroy.enabled = true in host-agent.toml.
# The wrapper itself rejects callers not in allowed_uids; sudoers just
# provides the privilege escalation path.
{{CLASH_AGENT_USER}} ALL=(root) NOPASSWD: /usr/local/sbin/zfs-destroy-wrapper

# ------ git-safe wrapper ---------------------------------------------------
# Allows clash-agent to run git status/fetch/pull/log/diff in allowlisted
# repositories only (validated against [git] allowed_repos in config).
{{CLASH_AGENT_USER}} ALL=(root) NOPASSWD: /usr/local/sbin/git-safe-wrapper

# ------ pct read-only operations (direct, no wrapper needed) ---------------
# Status is read-only; no wrapper overhead required.
{{CLASH_AGENT_USER}} ALL=(root) NOPASSWD: /usr/sbin/pct status *

# ------ zfs safe read-only operations (direct) -----------------------------
# List, get, and snapshot creation are non-destructive and do not need a
# wrapper.  Destroy is routed through zfs-destroy-wrapper above.
{{CLASH_AGENT_USER}} ALL=(root) NOPASSWD: /sbin/zfs list *
{{CLASH_AGENT_USER}} ALL=(root) NOPASSWD: /sbin/zfs get *
{{CLASH_AGENT_USER}} ALL=(root) NOPASSWD: /sbin/zfs snapshot *

# ------ explicitly DENY fallthrough to unrestricted binaries ---------------
# Belt-and-suspenders: if a future sudoers entry above were accidentally
# broadened, these Deny rules ensure the bare binaries cannot be invoked.
# (sudoers processes rules top-to-bottom; first match wins, so NOPASSWD:
#  entries above for wrappers take priority; these are safety backstops.)
{{CLASH_AGENT_USER}} ALL=(root) !NOPASSWD: /sbin/zfs destroy *
{{CLASH_AGENT_USER}} ALL=(root) !NOPASSWD: /usr/sbin/pct create *
{{CLASH_AGENT_USER}} ALL=(root) !NOPASSWD: /usr/bin/git *
